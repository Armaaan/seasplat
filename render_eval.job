#!/bin/bash
#SBATCH --job-name=seasplat_eiffel_render_eval
#SBATCH --output=logs/eiffel_tower/render_eval_%j.out
#SBATCH --cpus-per-task=4
#SBATCH --gres=gpu:a30:1
#SBATCH --partition=scavenge
#SBATCH --time=24:00:00


module purge
module load Anaconda3
module load CUDA/12.1.1

eval "$(conda shell.bash hook)"
conda activate seasplat

cd /home/arua/projects/3dgs/seasplat
mkdir -p logs/SeathruNeRF

# MODEL_PATH="/home/arua/projects/3dgs/datasets/prepared/SeathruNeRF/Curasao/experiments/05072026/Curasao_seasplat"
# SOURCE_PATH="/home/arua/projects/3dgs/datasets/prepared/SeathruNeRF/Curasao"

MODEL_PATH="/home/arua/projects/3dgs/datasets/prepared/Eiffel_Tower/subset/subset_50_1776x1182/experiments/05072026/seasplat_experiment_1"
SOURCE_PATH="/home/arua/projects/3dgs/datasets/prepared/Eiffel_Tower/subset/subset_50_1776x1182"

echo "--- Running render_uw.py ---"
python render_uw.py \
    -m ""$MODEL_PATH"" \
    -s "$SOURCE_PATH" \
    --skip_train \
    --seathru \
    --eval


echo "--- Running metrics.py ---"
python metrics.py \
    -m "$MODEL_PATH" \
    --comparison_dir "render" \
    --skip_train