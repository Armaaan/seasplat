#!/bin/bash
#SBATCH --job-name=seathruNeRF_JapaneseGradens-RedSea_render_eval
#SBATCH --output=logs/SeathruNeRF/JapaneseGradens-RedSea_render_eval_%j.out
#SBATCH --cpus-per-task=4
#SBATCH --gres=gpu:a30:1
#SBATCH --partition=scavenge
#SBATCH --time=24:00:00


module purge
module load Anaconda3
module load CUDA/12.1.1

eval "$(conda shell.bash hook)"
conda activate seasplat

cd /home/arua/projects/3dgs/seasplat
mkdir -p logs/SeathruNeRF

# Curasao
# MODEL_PATH="/home/arua/projects/3dgs/datasets/prepared/SeathruNeRF/Curasao/experiments/05072026/Curasao_seasplat"
# SOURCE_PATH="/home/arua/projects/3dgs/datasets/prepared/SeathruNeRF/Curasao"

# IUI3-RedSea
# MODEL_PATH="/home/arua/projects/3dgs/datasets/prepared/SeathruNeRF/IUI3-RedSea/experiments/05072026/IUI3-RedSea_seasplat"
# SOURCE_PATH="/home/arua/projects/3dgs/datasets/prepared/SeathruNeRF/IUI3-RedSea"

# JapaneseGradens-RedSea
MODEL_PATH="/home/arua/projects/3dgs/datasets/prepared/SeathruNeRF/JapaneseGradens-RedSea/experiments/05072026/JapaneseGradens-RedSea_seasplat"
SOURCE_PATH="/home/arua/projects/3dgs/datasets/prepared/SeathruNeRF/JapaneseGradens-RedSea"

# Panama
# MODEL_PATH="/home/arua/projects/3dgs/datasets/prepared/SeathruNeRF/Panama/experiments/05072026/Panama_seasplat"
# SOURCE_PATH="/home/arua/projects/3dgs/datasets/prepared/SeathruNeRF/Panama"

# Eiffel_Tower
# MODEL_PATH="/home/arua/projects/3dgs/datasets/prepared/Eiffel_Tower/subset/subset_50_1776x1182/experiments/05072026/seasplat_experiment_1"
# SOURCE_PATH="/home/arua/projects/3dgs/datasets/prepared/Eiffel_Tower/subset/subset_50_1776x1182"


echo "--- Running render_uw.py ---"
python render_uw.py \
    -m ""$MODEL_PATH"" \
    -s "$SOURCE_PATH" \
    --skip_train \
    --seathru \
    --eval


echo "--- Running metrics.py ---"

# For with_water
python metrics.py \
    -m "$MODEL_PATH" \
    --comparison_dir "with_water" \
    --skip_train

# For render
python metrics.py \
    -m "$MODEL_PATH" \
    --comparison_dir "render" \
    --skip_train