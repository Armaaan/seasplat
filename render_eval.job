#!/bin/bash
#SBATCH --job-name=seathruNeRF_curasao_render_eval
#SBATCH --output=logs/SeathruNeRF/curasao_render_eval_%j.out
#SBATCH --cpus-per-task=4
#SBATCH --gres=gpu:a30:1
#SBATCH --partition=scavenge
#SBATCH --time=24:00:00


module purge
module load Anaconda3
module load CUDA/12.1.1

eval "$(conda shell.bash hook)"
conda activate seasplat

cd /home/arua/projects/3dgs/seasplat
mkdir -p logs/SeathruNeRF

MODEL_PATH="/home/arua/projects/3dgs/datasets/prepared/SeathruNeRF/Curasao/experiments/05072026/Curasao_seasplat"

echo "--- Running render_uw.py ---"
python render_uw.py \
    -m "$MODEL_PATH" \
    --skip_train

echo "--- Running metrics.py ---"
python metrics.py \
    -m "$MODEL_PATH"

echo "--- Results ---"
cat "$MODEL_PATH/results.json"