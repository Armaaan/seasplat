#!/bin/bash
#SBATCH --job-name=colmap
#SBATCH --output=logs/colmap_%j.out
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=32G
#SBATCH --gres=gpu:a100_80gb:1
#SBATCH --time=24:00:00
#SBATCH --partition=acltr

set -euo pipefail

module purge
module load Anaconda3
module load CUDA/12.1.1

# FIX: Temporarily disable nounset (-u) so Conda can load without crashing
set +u
eval "$(conda shell.bash hook)"
conda activate seasplat
set -u

conda tos accept --channel https://repo.anaconda.com/pkgs/main
conda tos accept --channel https://repo.anaconda.com/pkgs/r

# conda install -c conda-forge colmap -y

cd /home/arua/projects/3dgs/seasplat
mkdir -p logs

# Sanity checks
python - <<'PY'
import torch
print(f"CUDA available: {torch.cuda.is_available()}")
PY

# Paths
SOURCE_PATH="/home/arua/projects/3dgs/datasets"
DATASET_NAME="IUI3-RedSea"
UNDISTORTED_PATH="${SOURCE_PATH}/undistorted_seathrunerf_dataset/seasplat/${DATASET_NAME}"


echo "Running COLMAP image_undistorter..."
colmap image_undistorter \
    --image_path "${SOURCE_PATH}/SeathruNeRF_dataset/${DATASET_NAME}/Images_wb" \
    --input_path "${SOURCE_PATH}/SeathruNeRF_dataset/${DATASET_NAME}/sparse/0" \
    --output_path "$UNDISTORTED_PATH" \
    --output_type COLMAP

echo "--- Undistortion Done ---"

colmap model_converter \
    --input_path "${UNDISTORTED_PATH}/sparse" \
    --output_path "${UNDISTORTED_PATH}/sparse/0" \
    --output_type TXT

echo "--- All Conversions Done. Starting Training ---"

echo "--- Starting Training ---"
python train.py \
    -s "$UNDISTORTED_PATH" \
    --exp "seasplat_${DATASET_NAME}" \
    --do_seathru --seathru_from_iter 10000